<!-- En-tête -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <p class="text-muted small mb-1">Tableau de bord</p>
    <h2 class="mb-0 fw-bold">Bonjour, <%= currentUser.prenom %> 👋</h2>
  </div>
  <a href="/profil" class="btn btn-light border shadow-sm">
    <i class="bi bi-person-gear"></i> Mon profil
  </a>
</div>

<div class="row g-3 mb-4">
  <!-- Carte solde héro (style carte bancaire) -->
  <div class="col-lg-7">
    <div class="card shadow-sm h-100" style="background: linear-gradient(135deg,#059669,#1c2536);">
      <div class="card-body text-white p-4 d-flex flex-column justify-content-between" style="min-height: 180px;">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="small opacity-75 mb-1">Solde total disponible</p>
            <h1 class="display-5 fw-bold mb-0"><%= fmt.formaterMontant(soldeTotal) %></h1>
          </div>
          <i class="bi bi-wallet2 fs-2 opacity-50"></i>
        </div>
        <div class="d-flex justify-content-between align-items-end">
          <span class="font-monospace small opacity-75">OUR BANK • <%= currentUser.prenom %> <%= currentUser.nom || '' %></span>
          <span class="badge bg-light text-dark"><%= comptes.length %> compte<%= comptes.length > 1 ? 's' : '' %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Stat rapides -->
  <div class="col-lg-5">
    <div class="row g-3 h-100">
      <div class="col-12">
        <div class="card shadow-sm h-100">
          <div class="card-body d-flex align-items-center gap-3">
            <div class="d-flex align-items-center justify-content-center flex-shrink-0"
                 style="width:48px;height:48px;border-radius:0.75rem;background:rgba(16,185,129,0.12);">
              <i class="bi bi-credit-card-2-front text-success fs-5"></i>
            </div>
            <div>
              <p class="text-muted small mb-0">Comptes actifs</p>
              <h4 class="mb-0 fw-bold"><%= comptes.filter(function(c){return c.statut === 'actif';}).length %></h4>
            </div>
          </div>
        </div>
      </div>
      <div class="col-12">
        <div class="card shadow-sm h-100">
          <div class="card-body d-flex align-items-center gap-3">
            <a href="/historique" class="text-decoration-none d-flex align-items-center gap-3 w-100 text-reset">
              <div class="d-flex align-items-center justify-content-center flex-shrink-0"
                   style="width:48px;height:48px;border-radius:0.75rem;background:rgba(28,37,54,0.08);">
                <i class="bi bi-clock-history fs-5" style="color:#1c2536;"></i>
              </div>
              <div>
                <p class="text-muted small mb-0">Historique</p>
                <span class="fw-semibold">Voir mes transactions <i class="bi bi-arrow-right"></i></span>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Mes comptes -->
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0 fw-bold">Mes comptes</h4>
  <a href="/comptes" class="btn btn-primary btn-sm">
    <i class="bi bi-grid"></i> Gérer mes comptes
  </a>
</div>

<% if (comptes.length === 0) { %>
  <div class="card shadow-sm">
    <div class="card-body text-center py-5">
      <i class="bi bi-piggy-bank text-muted" style="font-size:2.5rem;"></i>
      <p class="text-muted mt-3 mb-3">Vous n'avez encore aucun compte bancaire.</p>
      <a href="/comptes" class="btn btn-primary">Ouvrir mon premier compte</a>
    </div>
  </div>
<% } else { %>
  <div class="row g-3">
    <% comptes.forEach(function(c){ %>
      <div class="col-md-6">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <span class="badge bg-secondary"><%= fmt.libelleTypeCompte(c.type_compte) %></span>
              <span class="badge <%= c.statut === 'actif' ? 'bg-success' : 'bg-danger' %>">
                <i class="bi <%= c.statut === 'actif' ? 'bi-check-circle' : 'bi-lock' %>"></i>
                <%= c.statut === 'actif' ? 'Actif' : 'Bloqué' %>
              </span>
            </div>
            <p class="font-monospace small text-muted mb-2"><%= c.numero_compte %></p>
            <h3 class="mb-3 fw-bold"><%= fmt.formaterMontant(c.solde) %></h3>
            <a href="/comptes/<%= c.id %>" class="btn btn-sm btn-outline-primary w-100">
              Voir le détail <i class="bi bi-arrow-right"></i>
            </a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>