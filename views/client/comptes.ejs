<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <p class="text-muted small mb-1">Mon espace</p>
    <h2 class="mb-0 fw-bold">Mes comptes bancaires</h2>
  </div>
  <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalNouveauCompte">
    <i class="bi bi-plus-lg"></i> Nouveau compte
  </button>
</div>

<% if (comptes.length === 0) { %>
  <div class="card shadow-sm">
    <div class="card-body text-center py-5">
      <i class="bi bi-piggy-bank text-muted" style="font-size:2.5rem;"></i>
      <p class="text-muted mt-3 mb-3">Vous n'avez aucun compte pour le moment.</p>
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalNouveauCompte">
        <i class="bi bi-plus-lg"></i> Ouvrir mon premier compte
      </button>
    </div>
  </div>
<% } else { %>
  <div class="row g-3">
    <% comptes.forEach(function(c){ %>
      <div class="col-md-6 col-lg-4">
        <div class="card shadow-sm h-100">
          <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <span class="badge bg-secondary"><%= fmt.libelleTypeCompte(c.type_compte) %></span>
              <span class="badge <%= c.statut === 'actif' ? 'bg-success' : 'bg-danger' %>">
                <i class="bi <%= c.statut === 'actif' ? 'bi-check-circle' : 'bi-lock' %>"></i>
                <%= c.statut === 'actif' ? 'Actif' : 'Bloqué' %>
              </span>
            </div>

            <p class="text-muted small mb-1">Solde</p>
            <h3 class="fw-bold mb-3"><%= fmt.formaterMontant(c.solde) %></h3>

            <p class="font-monospace small text-muted mb-3"><%= c.numero_compte %></p>

            <div class="mt-auto d-flex gap-2">
              <a href="/comptes/<%= c.id %>" class="btn btn-sm btn-outline-primary flex-grow-1">
                Détail <i class="bi bi-arrow-right"></i>
              </a>
              <% if (parseFloat(c.solde) === 0) { %>
                <form action="/comptes/<%= c.id %>/supprimer" method="POST" class="d-inline form-suppr-compte"
                      data-iban="<%= c.numero_compte %>">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button class="btn btn-sm btn-outline-danger" type="submit" title="Supprimer ce compte">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<!-- Modal création de compte -->
<div class="modal fade" id="modalNouveauCompte" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <form action="/comptes" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="modal-header border-0">
          <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle text-success"></i> Ouvrir un nouveau compte</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <label class="form-label fw-semibold">Type de compte</label>
          <select name="type_compte" class="form-select form-select-lg" required>
            <option value="courant">Compte courant</option>
            <option value="livret_a">Livret A</option>
            <option value="pel">PEL</option>
          </select>
          <div class="alert alert-info mt-3 mb-0 small d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            L'IBAN sera généré automatiquement. Le solde initial est de 0 €.
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Annuler</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Créer le compte</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // Confirmation de suppression de compte (SweetAlert2)
  document.querySelectorAll('.form-suppr-compte').forEach((form) => {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      const iban = form.dataset.iban;
      Swal.fire({
        title: 'Supprimer ce compte ?',
        html: `Le compte <span class="font-monospace">${iban}</span> sera définitivement supprimé.<br>Cette action est irréversible.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Oui, supprimer',
        cancelButtonText: 'Annuler',
        confirmButtonColor: '#e24b4a',
      }).then((r) => { if (r.isConfirmed) form.submit(); });
    });
  });
</script>