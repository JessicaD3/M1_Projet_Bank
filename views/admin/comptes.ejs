<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <p class="text-muted small mb-1">Administration</p>
    <h2 class="mb-0 fw-bold">Tous les comptes bancaires</h2>
  </div>
  <a href="/admin/dashboard" class="btn btn-light border shadow-sm">
    <i class="bi bi-arrow-left"></i> Dashboard
  </a>
</div>

<% if (comptes.length === 0) { %>
  <div class="card shadow-sm">
    <div class="card-body text-center py-5">
      <i class="bi bi-credit-card text-muted" style="font-size:2.5rem;"></i>
      <p class="text-muted mt-3 mb-0">Aucun compte bancaire enregistré.</p>
    </div>
  </div>
<% } else { %>

  <!-- Synthèse rapide -->
  <%
    var totalSoldes = comptes.reduce(function(acc, c){ return acc + parseFloat(c.solde); }, 0);
    var nbActifs = comptes.filter(function(c){ return c.statut === 'actif'; }).length;
    var nbBloques = comptes.length - nbActifs;
  %>
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body d-flex align-items-center gap-3">
          <div class="d-flex align-items-center justify-content-center flex-shrink-0"
               style="width:48px;height:48px;border-radius:0.75rem;background:rgba(16,185,129,0.12);">
            <i class="bi bi-wallet2 text-success fs-5"></i>
          </div>
          <div>
            <p class="text-muted small mb-0">Encours total</p>
            <h5 class="mb-0 fw-bold"><%= fmt.formaterMontant(totalSoldes) %></h5>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body d-flex align-items-center gap-3">
          <div class="d-flex align-items-center justify-content-center flex-shrink-0"
               style="width:48px;height:48px;border-radius:0.75rem;background:rgba(16,185,129,0.12);">
            <i class="bi bi-check-circle text-success fs-5"></i>
          </div>
          <div>
            <p class="text-muted small mb-0">Comptes actifs</p>
            <h5 class="mb-0 fw-bold"><%= nbActifs %></h5>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body d-flex align-items-center gap-3">
          <div class="d-flex align-items-center justify-content-center flex-shrink-0"
               style="width:48px;height:48px;border-radius:0.75rem;background:rgba(226,74,74,0.10);">
            <i class="bi bi-lock fs-5 text-danger"></i>
          </div>
          <div>
            <p class="text-muted small mb-0">Comptes bloqués</p>
            <h5 class="mb-0 fw-bold"><%= nbBloques %></h5>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Recherche live -->
  <div class="mb-3">
    <div class="input-group shadow-sm">
      <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
      <input type="text" id="recherche" class="form-control border-start-0 ps-0"
        placeholder="Rechercher par titulaire, email, IBAN ou type..." autocomplete="off" />
    </div>
    <div class="form-text mt-1" id="compteur"></div>
  </div>

  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0" id="table-comptes">
        <thead class="table-light">
          <tr><th>Titulaire</th><th>IBAN</th><th>Type</th><th>Solde</th><th>Statut</th><th class="text-end">Actions</th></tr>
        </thead>
        <tbody>
          <% comptes.forEach(function(c){ %>
            <tr class="ligne-compte"
                data-recherche="<%= (c.prenom + ' ' + c.nom + ' ' + c.email + ' ' + c.numero_compte + ' ' + fmt.libelleTypeCompte(c.type_compte)).toLowerCase() %>">
              <td>
                <div class="fw-semibold"><%= c.prenom %> <%= c.nom %></div>
                <span class="small text-muted"><%= c.email %></span>
              </td>
              <td class="font-monospace small"><%= c.numero_compte %></td>
              <td class="small"><%= fmt.libelleTypeCompte(c.type_compte) %></td>
              <td class="fw-bold"><%= fmt.formaterMontant(c.solde) %></td>
              <td>
                <span class="badge <%= c.statut === 'actif' ? 'bg-success' : 'bg-danger' %>">
                  <i class="bi <%= c.statut === 'actif' ? 'bi-check-circle' : 'bi-lock' %>"></i>
                  <%= c.statut === 'actif' ? 'Actif' : 'Bloqué' %>
                </span>
              </td>
              <td class="text-end">
                <form action="/admin/comptes/<%= c.id %>/statut" method="POST" class="d-inline form-statut"
                      data-statut="<%= c.statut %>" data-iban="<%= c.numero_compte %>">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="retour" value="/admin/comptes" />
                  <button class="btn btn-sm <%= c.statut === 'actif' ? 'btn-outline-danger' : 'btn-outline-success' %>">
                    <i class="bi <%= c.statut === 'actif' ? 'bi-lock' : 'bi-unlock' %>"></i>
                    <%= c.statut === 'actif' ? 'Bloquer' : 'Débloquer' %>
                  </button>
                </form>
                <a href="/admin/comptes/<%= c.id %>/historique" class="btn btn-sm btn-light border">
                  <i class="bi bi-clock-history"></i> Historique
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <div id="aucun-resultat" class="alert alert-warning d-none mt-3">
    Aucun compte ne correspond à votre recherche.
  </div>
<% } %>

<script>
  // --- Recherche live ---
  const champ = document.getElementById('recherche');
  const lignes = Array.from(document.querySelectorAll('.ligne-compte'));
  const aucunResultat = document.getElementById('aucun-resultat');
  const compteur = document.getElementById('compteur');

  function filtrer() {
    const q = champ.value.trim().toLowerCase();
    let visibles = 0;
    lignes.forEach((ligne) => {
      const match = ligne.dataset.recherche.includes(q);
      ligne.classList.toggle('d-none', !match);
      if (match) visibles++;
    });
    aucunResultat.classList.toggle('d-none', visibles > 0);
    compteur.textContent = q
      ? `${visibles} résultat${visibles > 1 ? 's' : ''} sur ${lignes.length}`
      : `${lignes.length} compte${lignes.length > 1 ? 's' : ''} au total`;
  }

  if (champ) {
    champ.addEventListener('input', filtrer);
    filtrer();
  }

  // --- Confirmation blocage / déblocage ---
  document.querySelectorAll('.form-statut').forEach((form) => {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      const estActif = form.dataset.statut === 'actif';
      const iban = form.dataset.iban;

      if (!estActif) { // déblocage : peu risqué, direct
        form.submit();
        return;
      }

      Swal.fire({
        title: 'Bloquer ce compte ?',
        html: `Le compte <span class="font-monospace">${iban}</span> ne pourra plus effectuer d'opérations (dépôt, retrait, virement) tant qu'il est bloqué.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Oui, bloquer',
        cancelButtonText: 'Annuler',
        confirmButtonColor: '#e24b4a',
      }).then((r) => {
        if (r.isConfirmed) form.submit();
      });
    });
  });
</script>