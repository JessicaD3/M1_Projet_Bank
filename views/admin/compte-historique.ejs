<a href="/admin/comptes" class="btn btn-light border shadow-sm mb-3">
  <i class="bi bi-arrow-left"></i> Retour aux comptes
</a>

<!-- En-tête du compte -->
<div class="card shadow-sm mb-4" style="background: linear-gradient(135deg,#059669,#1c2536);">
  <div class="card-body text-white p-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
      <div>
        <p class="small opacity-75 mb-1">Historique du compte</p>
        <p class="font-monospace mb-1"><%= compte.numero_compte %></p>
        <p class="small opacity-75 mb-0">
          <i class="bi bi-person"></i> <%= compte.prenom %> <%= compte.nom %>
        </p>
      </div>
      <div class="text-end">
        <p class="small opacity-75 mb-1">Solde actuel</p>
        <h3 class="fw-bold mb-0"><%= fmt.formaterMontant(compte.solde) %></h3>
      </div>
    </div>
  </div>
</div>

<% if (transactions.length === 0) { %>
  <div class="card shadow-sm">
    <div class="card-body text-center py-5">
      <i class="bi bi-receipt text-muted" style="font-size:2.5rem;"></i>
      <p class="text-muted mt-3 mb-0">Aucune transaction pour ce compte.</p>
    </div>
  </div>
<% } else { %>
  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr><th>Date</th><th>Type</th><th>Détail</th><th class="text-end">Montant</th></tr>
        </thead>
        <tbody>
          <% transactions.forEach(function(t){ %>
            <%
              // Du point de vue de CE compte : crédit s'il est destinataire d'un virement reçu,
              // ou s'il s'agit d'un dépôt. Débit pour retrait et virement émis.
              var estCredit = (t.type_transaction === 'depot' || t.type_transaction === 'virement_recu');
            %>
            <tr>
              <td class="small text-muted"><%= fmt.formaterDateHeure(t.date_transaction) %></td>
              <td>
                <span class="badge <%= estCredit ? 'bg-success' : 'bg-secondary' %>">
                  <i class="bi <%= estCredit ? 'bi-arrow-down-left' : 'bi-arrow-up-right' %>"></i>
                  <%= fmt.libelleTypeTransaction(t.type_transaction) %>
                </span>
              </td>
              <td class="small text-muted">
                <%= t.libelle || '' %>
                <% if (t.dest_iban && t.type_transaction.indexOf('virement') === 0) { %>
                  <br><span class="font-monospace"><%= t.source_iban %> → <%= t.dest_iban %></span>
                <% } %>
              </td>
              <td class="text-end fw-bold <%= estCredit ? 'text-success' : 'text-danger' %>">
                <%= estCredit ? '+' : '−' %><%= fmt.formaterMontant(t.montant) %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>