<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <p class="text-muted small mb-1">Administration</p>
    <h2 class="mb-0 fw-bold">Gestion des clients</h2>
  </div>
  <a href="/admin/dashboard" class="btn btn-light border shadow-sm">
    <i class="bi bi-arrow-left"></i> Dashboard
  </a>
</div>

<% if (clients.length === 0 && !voirInactifs) { %>
  <div class="card shadow-sm">
    <div class="card-body text-center py-5">
      <i class="bi bi-people text-muted" style="font-size:2.5rem;"></i>
      <p class="text-muted mt-3 mb-0">Aucun client à afficher.</p>
    </div>
  </div>
<% } else { %>

  <!-- Synthèse + bascule -->
  <%
    var nbActifs = clients.filter(function(c){ return c.is_actif; }).length;
    var nbInactifs = clients.length - nbActifs;
  %>
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="card shadow-sm h-100">
        <div class="card-body d-flex align-items-center gap-3">
          <div class="d-flex align-items-center justify-content-center flex-shrink-0"
               style="width:48px;height:48px;border-radius:0.75rem;background:rgba(16,185,129,0.12);">
            <i class="bi bi-people-fill text-success fs-5"></i>
          </div>
          <div>
            <p class="text-muted small mb-0">Clients affichés</p>
            <h5 class="mb-0 fw-bold"><%= clients.length %>
              <% if (voirInactifs && nbInactifs > 0) { %>
                <span class="small fw-normal text-muted">(<%= nbActifs %> actifs, <%= nbInactifs %> désactivés)</span>
              <% } %>
            </h5>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-6 d-flex align-items-center justify-content-md-end">
      <div class="btn-group shadow-sm">
        <a href="/admin/clients" class="btn <%= voirInactifs ? 'btn-light border' : 'btn-primary' %>">
          <i class="bi bi-check-circle"></i> Actifs
        </a>
        <a href="/admin/clients?inactifs=1" class="btn <%= voirInactifs ? 'btn-primary' : 'btn-light border' %>">
          <i class="bi bi-archive"></i> Tous
        </a>
      </div>
    </div>
  </div>

  <!-- Recherche -->
  <div class="mb-3">
    <div class="input-group input-group-lg shadow-sm">
      <span class="input-group-text bg-white border-end-0">
        <i class="bi bi-search text-muted"></i>
      </span>
      <input type="text" id="recherche" class="form-control border-start-0 ps-0"
        placeholder="Rechercher par nom, prénom, email..." autocomplete="off" autofocus />
    </div>
    <div class="form-text mt-1" id="compteur"></div>
  </div>

  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0" id="table-clients">
        <thead class="table-light">
          <tr><th>Client</th><th>Email</th><th>Statut</th><th class="text-end">Actions</th></tr>
        </thead>
        <tbody>
          <% clients.forEach(function(c){ %>
            <%
              var bgAvatar = c.is_actif ? 'linear-gradient(135deg,#10b981,#047857)' : '#94a3b8';
              var initiales = (c.prenom ? c.prenom[0] : '').toUpperCase() + (c.nom ? c.nom[0] : '').toUpperCase();
            %>
            <tr class="ligne-client <%= c.is_actif ? '' : 'opacity-75' %>"
                data-recherche="<%= (c.nom + ' ' + c.prenom + ' ' + c.email + ' ' + (c.telephone||'')).toLowerCase() %>">
              <td>
                <div class="d-flex align-items-center gap-2">
                  <div class="avatar-init flex-shrink-0 d-flex align-items-center justify-content-center fw-bold text-white"
                      data-bg="<%= c.is_actif ? 'actif' : 'inactif' %>">
                    <%= (c.prenom ? c.prenom[0] : '').toUpperCase() %><%= (c.nom ? c.nom[0] : '').toUpperCase() %>
                  </div>
                  <span class="fw-semibold"><%= c.prenom %> <%= c.nom %></span>
                </div>
              </td>
              <td class="text-muted"><%= c.email %></td>
              <td>
                <% if (c.is_actif) { %>
                  <span class="badge bg-success"><i class="bi bi-check-circle"></i> Actif</span>
                <% } else { %>
                  <span class="badge bg-secondary"><i class="bi bi-pause-circle"></i> Désactivé</span>
                <% } %>
              </td>
              <td class="text-end">
                <a href="/admin/clients/<%= c.id %>" class="btn btn-sm btn-outline-primary">
                  <i class="bi bi-eye"></i> Détail
                </a>
                <form action="/admin/clients/<%= c.id %>/activation" method="POST" class="d-inline form-activation"
                      data-nom="<%= c.prenom %> <%= c.nom %>" data-actif="<%= c.is_actif ? '1' : '0' %>">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <% if (c.is_actif) { %>
                    <button type="submit" class="btn btn-sm btn-outline-warning">
                      <i class="bi bi-pause-circle"></i> Désactiver
                    </button>
                  <% } else { %>
                    <button type="submit" class="btn btn-sm btn-outline-success">
                      <i class="bi bi-play-circle"></i> Réactiver
                    </button>
                  <% } %>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <div id="aucun-resultat" class="alert alert-warning d-none mt-3">
    Aucun client ne correspond à votre recherche.
  </div>
<% } %>

<script>
  const champ = document.getElementById('recherche');
  const lignes = Array.from(document.querySelectorAll('.ligne-client'));
  const aucunResultat = document.getElementById('aucun-resultat');
  const compteur = document.getElementById('compteur');

  function filtrer() {
    const q = champ.value.trim().toLowerCase();
    let visibles = 0;
    lignes.forEach((ligne) => {
      const match = ligne.dataset.recherche.includes(q);
      ligne.classList.toggle('d-none', !match);
      if (match) visibles++;
    });
    aucunResultat.classList.toggle('d-none', visibles > 0);
    compteur.textContent = q
      ? `${visibles} résultat${visibles > 1 ? 's' : ''} sur ${lignes.length}`
      : `${lignes.length} client${lignes.length > 1 ? 's' : ''} affiché${lignes.length > 1 ? 's' : ''}`;
  }

  // --- Confirmation SweetAlert2 pour activation/désactivation ---
  document.querySelectorAll('.form-activation').forEach((form) => {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      const nom = form.dataset.nom;
      const estActif = form.dataset.actif === '1';

      if (!estActif) {
        form.submit();
        return;
      }

      Swal.fire({
        title: 'Désactiver ce client ?',
        html: `Le client <strong>${nom}</strong> sera masqué des listes et statistiques.<br>Ses données seront <strong>conservées</strong> et le compte pourra être réactivé.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Oui, désactiver',
        cancelButtonText: 'Annuler',
        confirmButtonColor: '#f5b841',
      }).then((r) => {
        if (r.isConfirmed) form.submit();
      });
    });
  });

  if (champ) {
    champ.addEventListener('input', filtrer);
    filtrer();
  }
</script>