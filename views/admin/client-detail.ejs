<a href="/admin/clients" class="btn btn-light border shadow-sm mb-3">
  <i class="bi bi-arrow-left"></i> Retour aux clients
</a>

<!-- En-tête client -->
<%
  var bgAvatarDetail = client.is_actif ? 'actif' : 'inactif';
  var initialesDetail = (client.prenom ? client.prenom[0] : '').toUpperCase() + (client.nom ? client.nom[0] : '').toUpperCase();
%>
<div class="card shadow-sm mb-4">
  <div class="card-body d-flex align-items-center gap-3 flex-wrap">
    <div class="avatar-lg flex-shrink-0 d-flex align-items-center justify-content-center fw-bold text-white"
         data-bg="<%= bgAvatarDetail %>">
      <%= initialesDetail %>
    </div>
    <div class="flex-grow-1">
      <h3 class="mb-1 fw-bold"><%= client.prenom %> <%= client.nom %></h3>
      <p class="text-muted mb-0"><i class="bi bi-envelope"></i> <%= client.email %></p>
    </div>
    <div>
      <% if (client.is_actif) { %>
        <span class="badge bg-success fs-6"><i class="bi bi-check-circle"></i> Actif</span>
      <% } else { %>
        <span class="badge bg-secondary fs-6"><i class="bi bi-pause-circle"></i> Désactivé</span>
      <% } %>
    </div>
  </div>
</div>

<% if (!client.is_actif) { %>
  <div class="alert alert-secondary d-flex align-items-center">
    <i class="bi bi-eye-slash me-2"></i>
    Ce client est <strong class="mx-1">désactivé</strong> : ses données sont masquées dans les listes et statistiques, mais conservées.
  </div>
<% } %>

<div class="row g-4">
  <!-- Formulaire de modification -->
  <div class="col-lg-6">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="card-title fw-bold mb-3"><i class="bi bi-pencil-square text-success"></i> Modifier les informations</h5>
        <form action="/admin/clients/<%= client.id %>" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="row">
            <div class="col-6 mb-3">
              <label class="form-label">Nom</label>
              <input type="text" name="nom" class="form-control" value="<%= client.nom %>" required />
            </div>
            <div class="col-6 mb-3">
              <label class="form-label">Prénom</label>
              <input type="text" name="prenom" class="form-control" value="<%= client.prenom %>" required />
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Email</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0"><i class="bi bi-envelope text-muted"></i></span>
              <input type="email" name="email" class="form-control border-start-0 ps-0" value="<%= client.email %>" required />
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Téléphone</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0"><i class="bi bi-telephone text-muted"></i></span>
              <input type="text" name="telephone" class="form-control border-start-0 ps-0" value="<%= client.telephone || '' %>" required />
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Adresse</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0"><i class="bi bi-geo-alt text-muted"></i></span>
              <input type="text" name="adresse" class="form-control border-start-0 ps-0" value="<%= client.adresse || '' %>" />
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Date de naissance</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0"><i class="bi bi-calendar3 text-muted"></i></span>
              <input type="date" name="date_naissance" class="form-control border-start-0 ps-0"
                value="<%= client.date_naissance ? new Date(client.date_naissance).toISOString().split('T')[0] : '' %>" />
            </div>
          </div>
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Enregistrer</button>
        </form>
      </div>
    </div>

    <!-- Gestion du statut + suppression -->
    <div class="card shadow-sm mt-3" style="border:1px solid #fbd5d5;">
      <div class="card-body">
        <h6 class="fw-bold mb-2"><i class="bi bi-gear text-muted"></i> Gestion du compte</h6>
        <p class="small text-muted mb-3">
          La désactivation masque le client et ses données sans les supprimer (réversible).
          La suppression définitive efface le client et tous ses comptes.
        </p>
        <div class="d-flex gap-2 flex-wrap">
          <form action="/admin/clients/<%= client.id %>/activation" method="POST" class="d-inline" id="form-activation"
                data-actif="<%= client.is_actif ? '1' : '0' %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <% if (client.is_actif) { %>
              <button type="submit" class="btn btn-outline-warning btn-sm">
                <i class="bi bi-pause-circle"></i> Désactiver
              </button>
            <% } else { %>
              <button type="submit" class="btn btn-outline-success btn-sm">
                <i class="bi bi-play-circle"></i> Réactiver
              </button>
            <% } %>
          </form>
          <form action="/admin/clients/<%= client.id %>/supprimer" method="POST" class="d-inline" id="form-suppression">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="btn btn-outline-danger btn-sm">
              <i class="bi bi-trash"></i> Supprimer définitivement
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Comptes du client -->
  <div class="col-lg-6">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="card-title fw-bold mb-3"><i class="bi bi-credit-card text-success"></i> Comptes (<%= comptes.length %>)</h5>
        <% if (comptes.length === 0) { %>
          <div class="text-center text-muted py-4">
            <i class="bi bi-inbox" style="font-size:2rem;"></i>
            <p class="mb-0 mt-2">Aucun compte.</p>
          </div>
        <% } else { %>
          <% comptes.forEach(function(c){ %>
            <div class="border rounded-3 p-3 mb-2">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="badge bg-secondary"><%= fmt.libelleTypeCompte(c.type_compte) %></span>
                <span class="badge <%= c.statut === 'actif' ? 'bg-success' : 'bg-danger' %>">
                  <i class="bi <%= c.statut === 'actif' ? 'bi-check-circle' : 'bi-lock' %>"></i>
                  <%= c.statut === 'actif' ? 'Actif' : 'Bloqué' %>
                </span>
              </div>
              <div class="font-monospace small text-muted"><%= c.numero_compte %></div>
              <div class="fw-bold fs-5 mb-2"><%= fmt.formaterMontant(c.solde) %></div>
              <div class="d-flex gap-1">
                <form action="/admin/comptes/<%= c.id %>/statut" method="POST" class="d-inline">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="retour" value="/admin/clients/<%= client.id %>" />
                  <button class="btn btn-sm <%= c.statut === 'actif' ? 'btn-outline-danger' : 'btn-outline-success' %>">
                    <i class="bi <%= c.statut === 'actif' ? 'bi-lock' : 'bi-unlock' %>"></i>
                    <%= c.statut === 'actif' ? 'Bloquer' : 'Débloquer' %>
                  </button>
                </form>
                <a href="/admin/comptes/<%= c.id %>/historique" class="btn btn-sm btn-light border">
                  <i class="bi bi-clock-history"></i> Historique
                </a>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
  // Couleur de l'avatar
  document.querySelectorAll('.avatar-lg').forEach((el) => {
    el.style.background = el.dataset.bg === 'actif'
      ? 'linear-gradient(135deg,#10b981,#047857)'
      : '#94a3b8';
  });

  const nomClient = "<%= client.prenom %> <%= client.nom %>";

  // --- Confirmation désactivation / réactivation ---
  const formActivation = document.getElementById('form-activation');
  formActivation.addEventListener('submit', function (e) {
    e.preventDefault();
    if (formActivation.dataset.actif === '0') {
      formActivation.submit();
      return;
    }
    Swal.fire({
      title: 'Désactiver ce client ?',
      html: `<strong>${nomClient}</strong> sera masqué des listes et statistiques.<br>Ses données seront <strong>conservées</strong> (réversible).`,
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: 'Oui, désactiver',
      cancelButtonText: 'Annuler',
      confirmButtonColor: '#f5b841',
    }).then((r) => { if (r.isConfirmed) formActivation.submit(); });
  });

  // --- Confirmation suppression définitive ---
  const formSuppression = document.getElementById('form-suppression');
  formSuppression.addEventListener('submit', function (e) {
    e.preventDefault();
    Swal.fire({
      title: 'Suppression définitive',
      html: `Supprimer définitivement <strong>${nomClient}</strong> et <strong>tous ses comptes</strong> ?<br>Cette action est <strong>irréversible</strong>.`,
      icon: 'error',
      showCancelButton: true,
      confirmButtonText: 'Oui, supprimer',
      cancelButtonText: 'Annuler',
      confirmButtonColor: '#e24b4a',
    }).then((r) => { if (r.isConfirmed) formSuppression.submit(); });
  });
</script>